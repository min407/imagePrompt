{
  "github": {
    "silent": true
  },
  "buildCommand": "./vercel-build.sh",
  "installCommand": "echo 'skip'",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "app/**/*.ts": {
      "runtime": "nodejs18.x"
    },
    "app/**/*.tsx": {
      "runtime": "nodejs18.x"
    }
  }
}
